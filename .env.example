# ── Directus ──────────────────────────────────────────────────────────────────
# Clé secrète JWT — générer avec : openssl rand -hex 32
SECRET=remplacer_par_une_chaine_aleatoire_64_caracteres

# URL publique de ton instance Directus (domaine prod)
PUBLIC_URL=https://api.ton-domaine.com

# URL(s) autorisées pour CORS (ton front Vue)
CORS_ORIGIN=https://ton-domaine.com

# Compte administrateur initial (créé au premier démarrage)
ADMIN_EMAIL=admin@ton-domaine.com
ADMIN_PASSWORD=remplacer_par_un_mot_de_passe_fort

# ── Base de données ────────────────────────────────────────────────────────────
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=remplacer_par_un_mot_de_passe_fort

